{
  "manifest_version": 3,
  "name": "AI Bookmarks Search",
  "version": "1.0.0",
  "description": "Search and chat with your bookmarks using AI. Powered by Gemini, OpenAI, and Claude for intelligent bookmark discovery.",
  "permissions": ["storage", "bookmarks"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Bookmarks Search",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
